# --- Database (PostgreSQL) ---
# Local docker:  postgresql://postgres:postgres@localhost:5432/app
# Neon/Supabase: copy the pooled connection string from the dashboard
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/app"
# If host port 5432 is already taken, set DB_PORT (compose reads this) to e.g.
# 5433 and change the port in DATABASE_URL above to match.
# DB_PORT=5433

# --- Better Auth ---
# Generate a secret: `openssl rand -base64 32`
BETTER_AUTH_SECRET="replace-me-with-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# --- Public ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
